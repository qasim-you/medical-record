<mxfile host="app.diagrams.net">
  <diagram name="Overall System Flowchart" id="flow_overall">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1400" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;Flowchart — Overall System Routing &amp; Logic&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="Start / Open DApp" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Check Wallet -->
        <mxCell id="chkWallet" value="Is MetaMask&#xa;Installed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="530" y="180" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="eStart" edge="1" source="start" target="chkWallet" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- No Wallet -->
        <mxCell id="noWallet" value="Show Error / Install Prompt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="750" y="195" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eNoWallet" value="No" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" edge="1" source="chkWallet" target="noWallet" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Wallet Connected, check role -->
        <mxCell id="chkRole" value="Check User Role&#xa;(ethers.js calls contract)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="515" y="300" width="170" height="80" as="geometry" />
        </mxCell>
        <mxCell id="eYesWallet" value="Yes" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" edge="1" source="chkWallet" target="chkRole" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Unregistered -->
        <mxCell id="routeUnreg" value="Route to /register" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="150" y="420" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eRoleUnreg" value="Not Registered" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" edge="1" source="chkRole" target="routeUnreg" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="230" y="340" /></Array></mxGeometry></mxCell>

        <!-- Admin Route -->
        <mxCell id="routeAdmin" value="Route to /admin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="350" y="420" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eRoleAdmin" value="Is Admin" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" edge="1" source="chkRole" target="routeAdmin" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="430" y="340" /></Array></mxGeometry></mxCell>

        <!-- Doctor Route -->
        <mxCell id="routeDoc" value="Route to /doctor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="680" y="420" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eRoleDoc" value="Is Doctor" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" edge="1" source="chkRole" target="routeDoc" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="760" y="340" /></Array></mxGeometry></mxCell>

        <!-- Patient Route -->
        <mxCell id="routePat" value="Route to /patient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="880" y="420" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eRolePat" value="Is Patient" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" edge="1" source="chkRole" target="routePat" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="960" y="340" /></Array></mxGeometry></mxCell>

        <!-- Activities (Generic Endings for Flowchart) -->
        <mxCell id="actEnd" value="Perform Actions&#xa;(Dashboard)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="520" y="520" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="eEndUnreg" edge="1" source="routeUnreg" target="actEnd" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="230" y="550" /></Array></mxGeometry></mxCell>
        <mxCell id="eEndAdmin" edge="1" source="routeAdmin" target="actEnd" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="430" y="550" /></Array></mxGeometry></mxCell>
        <mxCell id="eEndDoc" edge="1" source="routeDoc" target="actEnd" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="760" y="550" /></Array></mxGeometry></mxCell>
        <mxCell id="eEndPat" edge="1" source="routePat" target="actEnd" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="960" y="550" /></Array></mxGeometry></mxCell>

        <!-- Stop -->
        <mxCell id="stop" value="Stop / Disconnect" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="540" y="640" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="eStop" edge="1" source="actEnd" target="stop" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
