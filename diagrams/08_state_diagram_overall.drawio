<mxfile host="app.diagrams.net">
  <diagram name="Overall State Diagram" id="state_overall">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1400" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;State Diagram — Overall Patient &amp; Doctor Lifecycle&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="40" as="geometry" />
        </mxCell>

        <!-- Initial State -->
        <mxCell id="start" value="" style="ellipse;html=1;shape=mxgraph.flowchart.start_2;fillColor=#FFFFFF;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="580" y="80" width="40" height="40" as="geometry" />
        </mxCell>

        <!-- Doctor States -->
        <mxCell id="sDocInit" value="Unregistered User" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="250" y="160" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eStartDoc" edge="1" source="start" target="sDocInit" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sDocPending" value="Pending Doctor&#xa;(isRegistered=true, isVerified=false)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="230" y="260" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="eDocReg" value="registerDoctor()" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="220" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="eDocRegEdge" edge="1" source="sDocInit" target="sDocPending" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sDocVerified" value="Verified Doctor&#xa;(isVerified=true)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="230" y="380" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="eDocVer" value="verifyDoctor(doc, true)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="340" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="eDocVerEdge" edge="1" source="sDocPending" target="sDocVerified" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Patient States -->
        <mxCell id="sPatInit" value="Unregistered User" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="790" y="160" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eStartPat" edge="1" source="start" target="sPatInit" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sPatReg" value="Registered Patient&#xa;(isRegistered=true)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="770" y="260" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ePatReg" value="registerPatient()" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="810" y="220" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ePatRegEdge" edge="1" source="sPatInit" target="sPatReg" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Interaction States -->
        <mxCell id="sApptBooked" value="Appointment Booked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="500" y="480" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="eBookAppt" value="bookAppointment()" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="660" y="400" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="eBookApptEdge" edge="1" source="sPatReg" target="sApptBooked" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="870" y="510" /></Array></mxGeometry></mxCell>
        <mxCell id="eDocToAppt" edge="1" source="sDocVerified" target="sApptBooked" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="330" y="510" /></Array></mxGeometry></mxCell>

        <mxCell id="sApptDone" value="Consultation Completed&#xa;(isCompleted=true)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="500" y="600" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="eApptDone" value="completeAppointment()" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="600" y="560" width="140" height="20" as="geometry" />
        </mxCell>
        <mxCell id="eApptDoneEdge" edge="1" source="sApptBooked" target="sApptDone" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Final State -->
        <mxCell id="end" value="" style="ellipse;html=1;shape=mxgraph.flowchart.terminator;fillColor=#FFFFFF;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="580" y="720" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="eEnd" edge="1" source="sApptDone" target="end" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
