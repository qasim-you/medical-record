<mxfile host="app.diagrams.net">
  <diagram name="Data Flow Diagram Level 0" id="dfd0">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;HealthChain DApp — Data Flow Diagram (Level 0 Context)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- External Entities -->
        <mxCell id="ext_admin" value="Admin" style="shape=rectangle;rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ext_doctor" value="Doctor" style="shape=rectangle;rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="350" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ext_patient" value="Patient" style="shape=rectangle;rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="600" width="150" height="60" as="geometry" />
        </mxCell>

        <!-- Central Process -->
        <mxCell id="process" value="&lt;b&gt;0&lt;/b&gt;&#xa;&#xa;HealthChain&#xa;Decentralized&#xa;Healthcare&#xa;Management&#xa;System" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="450" y="250" width="250" height="250" as="geometry" />
        </mxCell>

        <!-- Data Stores -->
        <mxCell id="ds1" value="D1     Ethereum Blockchain&#xa;(Healthcare.sol Contract)" style="shape=partialRectangle;whiteSpace=wrap;html=1;left=1;right=0;top=0;bottom=0;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="150" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ds2" value="D2     IPFS / Pinata Cloud&#xa;(Decentralized File Storage)" style="shape=partialRectangle;whiteSpace=wrap;html=1;left=1;right=0;top=0;bottom=0;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="900" y="550" width="300" height="50" as="geometry" />
        </mxCell>

        <!-- Flows from Admin -->
        <mxCell id="f1" value="Verify Doctor Request&#xa;Add Medicine Data&#xa;Withdraw Revenue" style="endArrow=block;endFill=1;html=1;fontSize=10;align=left;" edge="1" source="ext_admin" target="process" parent="1"><mxGeometry x="-0.3" y="20" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        <mxCell id="f2" value="Platform Stats&#xa;Revenue Balance" style="endArrow=block;endFill=1;html=1;fontSize=10;dashed=1;align=left;" edge="1" source="process" target="ext_admin" parent="1"><mxGeometry x="-0.3" y="-20" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Flows from Doctor -->
        <mxCell id="f3" value="Registration Data&#xa;Medical Records&#xa;Prescriptions&#xa;Chat Messages" style="endArrow=block;endFill=1;html=1;fontSize=10;align=left;" edge="1" source="ext_doctor" target="process" parent="1"><mxGeometry x="-0.3" y="20" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        <mxCell id="f4" value="Patient List&#xa;Appointment Queue&#xa;Verification Status" style="endArrow=block;endFill=1;html=1;fontSize=10;dashed=1;align=left;" edge="1" source="process" target="ext_doctor" parent="1"><mxGeometry x="-0.3" y="-20" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Flows from Patient -->
        <mxCell id="f5" value="Registration Data&#xa;Appointment Booking (ETH)&#xa;Medicine Purchase (ETH)&#xa;Chat Messages" style="endArrow=block;endFill=1;html=1;fontSize=10;align=left;" edge="1" source="ext_patient" target="process" parent="1"><mxGeometry x="-0.3" y="20" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        <mxCell id="f6" value="Doctor List&#xa;Medical History&#xa;Prescriptions&#xa;AI Suggestions" style="endArrow=block;endFill=1;html=1;fontSize=10;dashed=1;align=left;" edge="1" source="process" target="ext_patient" parent="1"><mxGeometry x="-0.3" y="-20" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Flows to Data Stores -->
        <mxCell id="f7" value="Read/Write Transactions&#xa;(Structs, Mappings, Events)" style="endArrow=block;endFill=1;html=1;fontSize=10;" edge="1" source="process" target="ds1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f8" value="Query State Data" style="endArrow=block;endFill=1;html=1;fontSize=10;dashed=1;" edge="1" source="ds1" target="process" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f9" value="Upload Image/Cert Files" style="endArrow=block;endFill=1;html=1;fontSize=10;" edge="1" source="process" target="ds2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="f10" value="Return CID/URI" style="endArrow=block;endFill=1;html=1;fontSize=10;dashed=1;" edge="1" source="ds2" target="process" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
