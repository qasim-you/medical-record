<mxfile host="app.diagrams.net">
  <diagram name="State Diagram - Doctor Lifecycle" id="state1">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" background="#FFFFFF" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;State Diagram — Doctor Lifecycle&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="" style="ellipse;html=1;shape=mxgraph.flowchart.start_2;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- States -->
        <mxCell id="s1" value="Guest&#xa;(Unregistered)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="130" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="Registered&#xa;(Unverified)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="130" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="Verified&#xa;(Active Doctor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="130" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="Consulting&#xa;(Appointment Active)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="130" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="Prescribing&#xa;(Issuing Rx)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="300" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="Messaging&#xa;(P2P Chat)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="300" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="Suspended&#xa;(Unverified by Admin)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="450" width="170" height="70" as="geometry" />
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="" style="ellipse;html=1;shape=mxgraph.flowchart.terminate;fillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="195" y="475" width="30" height="30" as="geometry" />
        </mxCell>

        <!-- Transitions -->
        <mxCell id="t0" edge="1" source="start" target="s1" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t1" value="registerDoctor()&#xa;+ pay fee" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="s1" target="s2" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t2" value="Admin calls&#xa;verifyDoctor(true)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="s2" target="s3" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t3" value="Patient books&#xa;appointment" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="s3" target="s4" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t4" value="completeAppointment()" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;curved=1;" edge="1" source="s4" target="s3" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="810" y="100" /><mxPoint x="695" y="100" /></Array></mxGeometry></mxCell>
        <mxCell id="t5" value="prescribeMedicine()" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="s3" target="s5" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="800" y="335" /></Array></mxGeometry></mxCell>
        <mxCell id="t6" value="Rx issued" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;" edge="1" source="s5" target="s3" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1100" y="335" /><mxPoint x="1100" y="165" /></Array></mxGeometry></mxCell>
        <mxCell id="t7" value="sendMessage()" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;" edge="1" source="s3" target="s6" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t8" value="return to Active" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;dashed=1;" edge="1" source="s6" target="s3" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="580" y="250" /></Array></mxGeometry></mxCell>
        <mxCell id="t9" value="Admin calls&#xa;verifyDoctor(false)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#000000;" edge="1" source="s3" target="s7" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="695" y="485" /></Array></mxGeometry></mxCell>
        <mxCell id="t10" value="Admin re-verifies" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;strokeColor=#000000;" edge="1" source="s7" target="s3" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="465" y="380" /><mxPoint x="620" y="380" /></Array></mxGeometry></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
